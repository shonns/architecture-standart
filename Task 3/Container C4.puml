@startuml Диаграмма контейнеров - Система открытия депозитов
!include <C4/C4_Container>

title Диаграмма контейнеров - Система открытия депозитов в банке "Стандарт"

Person(клиент, "Клиент", "Физическое лицо, желающее открыть депозит")

System_Boundary(система_банка, "Банковская система") {
    Container(интернет_банк, "Интернет-банк", "ASP.NET", "Веб-приложение для существующих клиентов")
    Container(сайт, "Сайт банка", "PHP, React.js", "Корпоративный сайт с формой заявки")
    Container(api_gateway, "API Gateway", "Kong/Nginx", "Единая точка входа для API, аутентификация, авторизация")
    Container(сервис_депозитов, "Сервис депозитов", "Node.js/Spring Boot", "Обработка заявок на депозиты")
    ContainerDb(бд_депозитов, "База данных депозитов", "PostgreSQL", "Хранение заявок и данных депозитов")
}

System(абс, "АБС", "Delphi, Oracle", "Основная банковская система")
System(колцентр, "Кол-центр", "Java Spring Boot, PostgreSQL", "Система обработки звонков")
System(смс_шлюз, "СМС-шлюз", "Внутренняя разработка", "Система отправки SMS")
System(телеком, "Телеком-оператор", "Внешняя система", "Оператор связи для отправки SMS")

Rel(клиент, интернет_банк, "Подает заявку на депозит", "HTTPS")
Rel(клиент, сайт, "Заполняет форму заявки", "HTTPS")

Rel(интернет_банк, api_gateway, "Вызывает API для обработки заявки", "REST API")
Rel(сайт, api_gateway, "Вызывает API для обработки заявки", "REST API")

Rel(api_gateway, сервис_депозитов, "Перенаправляет запросы", "REST API")

Rel(сервис_депозитов, бд_депозитов, "Сохраняет/читает данные заявок", "JDBC")
Rel(сервис_депозитов, абс, "Проверяет данные клиента, создает заявки/ АБС Отправляет статус по заявке", "DB API/Web Service")
Rel(абс, сервис_депозитов, "", "DB API/Web Service")
Rel(сервис_депозитов, смс_шлюз, "Отправляет уведомления", "REST API")
Rel(сервис_депозитов, колцентр, "Передает данные для обратной связи", "REST API")

Rel(смс_шлюз, телеком, "Отправляет SMS сообщения", "SMPP")

Rel(абс, смс_шлюз, "Отправляет уведомления о статусе", "DB Integration")

@enduml