@startuml Контекстная диаграмма - Процесс открытия депозитов
!include <C4/C4_Context>

title Контекстная диаграмма - Процесс открытия депозитов в банке "Стандарт"

Person(клиент, "Клиент", "Физическое лицо, желающее открыть депозит в банке")

System(интернет_банк, "Интернет-банк", "Веб-приложение для существующих клиентов банка")
System(сайт, "Сайт банка", "Корпоративный сайт с формой заявки на депозит")
System(api_gateway, "API Gateway", "Единая точка входа для API-запросов")
System(абс, "АБС", "Автоматизированная банковская система", "Основная система учета операций")
System(колцентр, "Кол-центр", "Система обработки звонков клиентов")
System(смс_шлюз, "СМС-шлюз", "Система отправки SMS-уведомлений")
System(бэк_офис, "Бэк-офис", "Сотрудники депозитного отдела")

Rel(клиент, интернет_банк, "Подает заявку на открытие депозита")
Rel(клиент, сайт, "Заполняет форму заявки на депозит")
Rel(клиент, колцентр, "Консультируется по условиям депозита")

Rel(интернет_банк, api_gateway, "Отправляет API-запросы", "HTTPS/REST")
Rel(сайт, api_gateway, "Отправляет API-запросы", "HTTPS/REST")
Rel(api_gateway, абс, "Проверяет данные клиента, создает заявку", "API")
Rel(абс, бэк_офис, "Передает заявки на обработку", "Внутренний API")
Rel(бэк_офис, абс, "Обрабатывает и подтверждает заявки", "Внутренний API")
Rel(абс, смс_шлюз, "Отправляет уведомления о статусе заявки", "API")
Rel(колцентр, абс, "Проверяет информацию о клиентах и продуктах", "API")

@enduml