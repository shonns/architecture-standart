@startuml Контекстная диаграмма - Интеграция ставок с кол-центрами
!include <C4/C4_Context>

title Контекстная диаграмма - Интеграция ставок с кол-центрами

Person(оператор, "Оператор кол-центра", "Сотрудник кол-центра, консультирующий клиентов")
Person(оператор2, "Оператор внешнего кол-центра", "Сотрудник внешнего кол-центра, консультирующий клиентов")
System(абс, "АБС", "Автоматизированная банковская система", "Основная система учета операций и ставок")
System(кц_банка, "Кол-центр банка", "Внутренняя система кол-центра", "Система обработки звонков")
System(кц_партнера, "Партнерский кол-центр", "Внешняя система кол-центра", "Система обработки звонков партнера")
System(sftp, "SFTP-сервер", "Сервер передачи файлов", "Обеспечивает передачу файлов с ставками")

Rel(оператор, кц_банка, "Консультирует клиентов по ставкам")
Rel(кц_банка, абс, "Запрашивает актуальные ставки", "API")
Rel(абс, sftp, "Передает файлы с ставками", "SFTP")
Rel(кц_партнера, sftp, "Забирает файлы с ставками", "SFTP")
Rel(оператор2, кц_партнера, "Консультирует клиентов по ставкам")

@enduml